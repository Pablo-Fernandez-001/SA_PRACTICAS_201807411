  "panels": [

    {
      "type": "stat",
      "title": "CPU (Prometheus)",
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 0 },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus-main"
      },
      "targets": [
        {
          "expr": "rate(process_cpu_seconds_total[1m])",
          "legendFormat": "cpu"
        }
      ]
    },
    {
      "type": "stat",
      "title": "RAM (Prometheus)",
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 0 },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus-main"
      },
      "targets": [
        {
          "expr": "process_resident_memory_bytes",
          "legendFormat": "ram"
        }
      ]
    },

