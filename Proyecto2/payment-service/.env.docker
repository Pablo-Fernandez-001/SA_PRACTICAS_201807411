# Payment Service Environment Variables (Docker)
PORT=3006
NODE_ENV=production

# Database
DB_HOST=payment-db
DB_PORT=3306
DB_USER=root
DB_PASSWORD=password
DB_NAME=payment_db

# Services
ORDERS_SERVICE_URL=http://orders-service:3003
FX_SERVICE_URL=http://fx-service:5000
NOTIFICATION_SERVICE_URL=http://notification-service:3005

# Logging
LOG_LEVEL=info
