# Catalog Service Environment Variables (Docker)
PORT=3002
GRPC_PORT=50052
NODE_ENV=production

# Database — points to Docker network hostname
DB_HOST=catalog-db
DB_PORT=3306
DB_USER=root
DB_PASSWORD=password
DB_NAME=catalog_db

# RabbitMQ — message broker for async events
RABBITMQ_URL=amqp://delivereats:rabbitmq2024@rabbitmq:5672

# Logging
LOG_LEVEL=info
